# Raven (macOS): drop the two safe_browsing deps that ungoogled leaves dangling in
# //chrome/test:unit_tests when safe_browsing is disabled — archive_analyzer_results
# and disk_image_type_sniffer_mac are undefined, so `gn gen` fails with
# "Unresolved dependencies" (ungoogled issue #626). These deps sit in the is_mac
# block of unit_tests, which is why only macOS trips on it.
#
# Minimal extract of ungoogled-chromium-macos fix-disabling-safebrowsing.patch
# (@150.0.7871.46-1.1). Raven needs ONLY this hunk — the upstream patch also strips
# safe_browsing deps from chrome/browser/ui|extensions|file_util, but those resolve
# fine in raven's config (the gn error listed only the unit_tests deps), so removing
# them would be wrong. The full upstream patch is vendored (inactive) alongside.
--- a/chrome/test/BUILD.gn
+++ b/chrome/test/BUILD.gn
@@ -8038,8 +8038,6 @@ test("unit_tests") {
       "//chrome/browser/mac:unit_tests",
       "//chrome/browser/renderer_host:history_swiper",
       "//chrome/common/notifications",
-      "//chrome/common/safe_browsing:archive_analyzer_results",
-      "//chrome/common/safe_browsing:disk_image_type_sniffer_mac",
       "//chrome/services/mac_notifications:unit_tests",
       "//chrome/services/mac_notifications/public/mojom",
       "//chrome/utility/safe_browsing",
