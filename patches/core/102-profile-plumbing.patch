new file mode 100644
index 0000000000000..e05a6e2129b4b
--- /dev/null
+++ b/components/ungoogled/fingerprint_profile_data.cc
@@ -0,0 +1,66 @@
+// Copyright (c) 2020 The ungoogled-chromium Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "components/ungoogled/fingerprint_profile_data.h"
+
+#include <string>
+
+#include "base/base64.h"
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/no_destructor.h"
+#include "components/ungoogled/ungoogled_switches.h"
+
+namespace ungoogled {
+
+namespace {
+
+// Process-wide cache for the base64 descriptor blob. Held in a
+// base::NoDestructor to avoid an exit-time destructor for the std::string.
+std::string* CacheStorage() {
+  static base::NoDestructor<std::string> cache;
+  return cache.get();
+}
+
+// Reads the descriptor JSON referenced by --fingerprint-profile and returns it
+// base64-encoded, or an empty string on any error (switch absent, empty path,
+// or unreadable file).
+std::string ComputeFromDescriptor() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(switches::kFingerprintProfile)) {
+    return std::string();
+  }
+
+  const base::FilePath path =
+      command_line->GetSwitchValuePath(switches::kFingerprintProfile);
+  if (path.empty()) {
+    return std::string();
+  }
+
+  std::string json;
+  if (!base::ReadFileToString(path, &json)) {
+    return std::string();
+  }
+
+  return base::Base64Encode(json);
+}
+
+}  // namespace
+
+void InitFingerprintProfileData() {
+  static bool initialized = false;
+  if (initialized) {
+    return;
+  }
+  initialized = true;
+  *CacheStorage() = ComputeFromDescriptor();
+}
+
+const std::string& GetFingerprintProfileData() {
+  return *CacheStorage();
+}
+
+}  // namespace ungoogled
diff --git a/components/ungoogled/fingerprint_profile_data.h b/components/ungoogled/fingerprint_profile_data.h
new file mode 100644
index 0000000000000..9cca532fbd3ff
--- /dev/null
+++ b/components/ungoogled/fingerprint_profile_data.h
@@ -0,0 +1,44 @@
+// Copyright (c) 2020 The ungoogled-chromium Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// Raven: renderer-bound fingerprint descriptor blob, read once at startup.
+//
+// The browser reads the JSON descriptor referenced by the --fingerprint-profile
+// switch once, during browser startup (from a phase where blocking file I/O is
+// still permitted, e.g. PreCreateThreads), base64-encodes it, and caches it.
+// When a renderer is later spawned, RenderProcessHostImpl copies the cached
+// value into the child command line as --fingerprint-profile-data with no I/O.
+//
+// Reading the descriptor lazily on the first renderer spawn (the previous
+// core/102 behaviour) runs base::ReadFileToString on the UI thread inside
+// RenderProcessHostImpl::Init. After startup the UI thread is a
+// disallow-blocking scope (base::DisallowUnresponsiveTasks), so the first
+// *post-startup* renderer spawn — e.g. a CDP Target.createTarget from a driver
+// that pre-warmed no page (stock go-rod / chromedp) — fatally DCHECKs and aborts
+// the browser (tracked as R12). Reading once at startup avoids that entirely.
+
+#ifndef COMPONENTS_UNGOOGLED_FINGERPRINT_PROFILE_DATA_H_
+#define COMPONENTS_UNGOOGLED_FINGERPRINT_PROFILE_DATA_H_
+
+#include <string>
+
+#include "base/component_export.h"
+
+namespace ungoogled {
+
+// Reads and caches the base64(compact-json) fingerprint descriptor blob.
+// Performs blocking file I/O and MUST be called once during startup from a
+// phase where that is allowed (before base::DisallowUnresponsiveTasks).
+// Idempotent: only the first call does work. Leaves the cache empty when the
+// --fingerprint-profile switch is absent or the descriptor is unreadable.
+COMPONENT_EXPORT(UNGOOGLED) void InitFingerprintProfileData();
+
+// Returns the cached base64 descriptor blob (empty when no valid descriptor was
+// supplied). Does no I/O and is safe to call from any thread after
+// InitFingerprintProfileData().
+COMPONENT_EXPORT(UNGOOGLED) const std::string& GetFingerprintProfileData();
+
+}  // namespace ungoogled
+
+#endif  // COMPONENTS_UNGOOGLED_FINGERPRINT_PROFILE_DATA_H_
