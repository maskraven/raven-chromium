@@ -0,0 +1,94 @@
+// Copyright (c) 2020 The ungoogled-chromium Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "components/ungoogled/fingerprint_accept_language.h"
+
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/json/json_reader.h"
+#include "base/no_destructor.h"
+#include "base/strings/string_util.h"
+#include "base/values.h"
+#include "components/ungoogled/ungoogled_switches.h"
+
+namespace ungoogled {
+
+namespace {
+
+// Process-wide cache for the joined Accept-Language source string. Held in a
+// base::NoDestructor to avoid an exit-time destructor for the std::string.
+std::string* CacheStorage() {
+  static base::NoDestructor<std::string> cache;
+  return cache.get();
+}
+
+// Reads the descriptor JSON referenced by --fingerprint-profile and returns its
+// "languages" tags joined as a comma-separated string, or an empty string on
+// any error (switch absent, empty/unreadable path, malformed JSON, or a
+// missing/empty "languages" list).
+std::string ComputeFromDescriptor() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(switches::kFingerprintProfile)) {
+    return std::string();
+  }
+
+  const base::FilePath path =
+      command_line->GetSwitchValuePath(switches::kFingerprintProfile);
+  if (path.empty()) {
+    return std::string();
+  }
+
+  std::string json;
+  if (!base::ReadFileToString(path, &json)) {
+    return std::string();
+  }
+
+  std::optional<base::DictValue> root =
+      base::JSONReader::ReadDict(json, base::JSON_PARSE_RFC);
+  if (!root) {
+    return std::string();
+  }
+
+  const base::ListValue* languages = root->FindList("languages");
+  if (!languages) {
+    return std::string();
+  }
+
+  std::vector<std::string> tags;
+  tags.reserve(languages->size());
+  for (const base::Value& item : *languages) {
+    const std::string* tag = item.GetIfString();
+    if (tag && !tag->empty()) {
+      tags.push_back(*tag);
+    }
+  }
+  if (tags.empty()) {
+    return std::string();
+  }
+
+  return base::JoinString(tags, ",");
+}
+
+}  // namespace
+
+void InitFingerprintAcceptLanguages() {
+  static bool initialized = false;
+  if (initialized) {
+    return;
+  }
+  initialized = true;
+  *CacheStorage() = ComputeFromDescriptor();
+}
+
+const std::string& GetFingerprintAcceptLanguages() {
+  return *CacheStorage();
+}
+
+}  // namespace ungoogled
