+++ b/components/ungoogled/fingerprint_accept_language.h
@@ -0,0 +1,38 @@
+// Copyright (c) 2020 The ungoogled-chromium Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// Raven: coherent Accept-Language sourced from the fingerprint descriptor.
+//
+// Reads the "languages" list from the JSON descriptor referenced by the
+// --fingerprint-profile switch once, during browser startup (from a phase where
+// blocking file I/O is still permitted, e.g. PreCreateThreads), joins the tags
+// into a comma-separated Accept-Language source string, and caches it. Callers
+// on any thread then read the cached value with no I/O, so the HTTP request
+// header and the service-worker language list co-vary with the spoofed
+// navigator.languages.
+
+#ifndef COMPONENTS_UNGOOGLED_FINGERPRINT_ACCEPT_LANGUAGE_H_
+#define COMPONENTS_UNGOOGLED_FINGERPRINT_ACCEPT_LANGUAGE_H_
+
+#include <string>
+
+#include "base/component_export.h"
+
+namespace ungoogled {
+
+// Reads and caches the fingerprint descriptor's language list. Performs
+// blocking file I/O and MUST be called once during startup from a phase where
+// that is allowed (before base::DisallowUnresponsiveTasks). Idempotent: only
+// the first call does work. Leaves the cache empty when the switch is absent or
+// the descriptor is missing/invalid.
+COMPONENT_EXPORT(UNGOOGLED) void InitFingerprintAcceptLanguages();
+
+// Returns the cached comma-separated Accept-Language source string (e.g.
+// "en-US,en"). Empty when no valid descriptor was supplied. Does no I/O and is
+// safe to call from any thread after InitFingerprintAcceptLanguages().
+COMPONENT_EXPORT(UNGOOGLED) const std::string& GetFingerprintAcceptLanguages();
+
+}  // namespace ungoogled
+
+#endif  // COMPONENTS_UNGOOGLED_FINGERPRINT_ACCEPT_LANGUAGE_H_
