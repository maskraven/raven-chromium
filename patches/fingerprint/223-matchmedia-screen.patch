+// Raven: the DEVICE-dimension media features (device-width, device-height,
+// device-aspect-ratio, resolution / -webkit-device-pixel-ratio) must co-vary
+// with the spoofed window.screen surface (fingerprint patch 203). Otherwise a
+// detector (CreepJS) can catch matchMedia('(device-width: <screen.width>px)')
+// disagreeing with the spoofed screen.width. When the fingerprint Profile is
+// active and the descriptor carries a positive value, these helpers return the
+// spoofed screen dimension / device pixel ratio; otherwise they fall through to
+// the real host value. The VIEWPORT features (width, height, aspect-ratio)
+// reflect the real window geometry and are intentionally left untouched.
+static int EffectiveDeviceWidth(const MediaValues& media_values) {
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active() && profile.descriptor().screen.w > 0) {
+    return profile.descriptor().screen.w;
+  }
+  return media_values.DeviceWidth();
+}
+
+static int EffectiveDeviceHeight(const MediaValues& media_values) {
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active() && profile.descriptor().screen.h > 0) {
+    return profile.descriptor().screen.h;
+  }
+  return media_values.DeviceHeight();
+}
+
+// Returns the effective device pixel ratio in dppx. EvalResolution normalizes
+// every 'resolution' query (dppx/dpi/dpcm) to dppx before comparing, and dppx
+// is numerically identical to window.devicePixelRatio, so descriptor.screen.dpr
+// is returned verbatim with no unit conversion.
+static double EffectiveDevicePixelRatio(const MediaValues& media_values) {
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active() && profile.descriptor().screen.dpr > 0) {
+    return profile.descriptor().screen.dpr;
+  }
+  return media_values.DevicePixelRatio();
+}
