+//
+// GENERATED FILE - DO NOT EDIT.
+// Produced by third_party/.../webgl/gen_webgl_table.py from
+// profile-db/webgl/webgl-gpu-params.json. Regenerate rather than editing.
+//
+// Self-contained persona GPU parameter table. GL enum values are inlined
+// as hex (matching third_party/khronos/GLES2/gl2.h + GLES3/gl3.h) so this
+// header pulls in no GL headers of its own.
+
+#ifndef THIRD_PARTY_BLINK_RENDERER_MODULES_WEBGL_WEBGL_PERSONA_PARAMS_DATA_H_
+#define THIRD_PARTY_BLINK_RENDERER_MODULES_WEBGL_WEBGL_PERSONA_PARAMS_DATA_H_
+
+#include <cstddef>
+#include <cstdint>
+
+namespace blink {
+namespace webgl_persona {
+namespace data {
+
+// pname is the GL enum (GLenum == uint32_t); typed value follows.
+struct IntCap {
+  uint32_t pname;
+  int32_t value;
+};
+struct Int64Cap {
+  uint32_t pname;
+  int64_t value;
+};
+struct FloatCap {
+  uint32_t pname;
+  float value;
+};
+struct FloatArr2Cap {
+  uint32_t pname;
+  float v0;
+  float v1;
+};
+struct IntArr2Cap {
+  uint32_t pname;
+  int32_t v0;
+  int32_t v1;
+};
+
+struct PersonaEntry {
+  const char* key;                 // dataset key (diagnostics only)
+  const char* os;                  // "windows" | "macos" | "linux"
+  const char* renderer_substring;  // case-insensitive 'contains' match
+  const char* unmasked_vendor;     // reference data / self-test
+  const char* unmasked_renderer;   // reference data / self-test
+  const char* gl_version_webgl1;
+  const char* gl_version_webgl2;
+  const char* glsl_version_webgl1;
+  const char* glsl_version_webgl2;
+  const IntCap* int_caps;
+  size_t int_caps_count;
+  const Int64Cap* int64_caps;
+  size_t int64_caps_count;
+  const FloatCap* float_caps;
+  size_t float_caps_count;
+  const FloatArr2Cap* float_arr2_caps;
+  size_t float_arr2_caps_count;
+  const IntArr2Cap* int_arr2_caps;
+  size_t int_arr2_caps_count;
+  bool has_float_precision;
+  int32_t float_precision[3];      // FLOAT: [range_min, range_max, precision]
+  const char* const* extensions1;
+  size_t extensions1_count;
+  const char* const* extensions2;
+  size_t extensions2_count;
+};
+
+// ---- nvidia-rtx-3060-d3d11 ----
