diff --git a/third_party/blink/renderer/modules/webgl/webgl_persona_params.cc b/third_party/blink/renderer/modules/webgl/webgl_persona_params.cc
new file mode 100644
index 0000000000000..506063d3708cb
--- /dev/null
+++ b/third_party/blink/renderer/modules/webgl/webgl_persona_params.cc
@@ -0,0 +1,240 @@
+// Copyright 2026 The Raven Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license.
+
+#include "third_party/blink/renderer/modules/webgl/webgl_persona_params.h"
+
+#include <cstddef>
+#include <string>
+#include <string_view>
+
+#include "third_party/blink/renderer/modules/webgl/webgl_persona_params_data.h"
+#include "third_party/blink/renderer/platform/fingerprint/profile.h"
+
+// ---------------------------------------------------------------------------
+// SelfTest (compile-in behavior notes; no runtime test framework here)
+//
+// Given descriptor { active, os="windows", gpu.renderer="ANGLE (NVIDIA, NVIDIA
+// GeForce RTX 3060 (0x00002504) Direct3D11 vs_5_0 ps_5_0, D3D11)" }:
+//   Active()                                   -> true  (row "nvidia-rtx-3060-d3d11")
+//   MaybeInt(GL_MAX_TEXTURE_SIZE=0x0D33,&i)    -> true,  i = 16384
+//   MaybeInt64(GL_MAX_ELEMENT_INDEX=0x8D6B,&l) -> true,  l = 4294967294
+//   MaybeFloatArray2(GL_ALIASED_POINT_SIZE_RANGE=0x846D,f) -> true, f={1,1024}
+//   MaybeIntArray2(GL_MAX_VIEWPORT_DIMS=0x0D3A,v) -> true, v={32767,32767}
+//   MaybePrecision(GL_FRAGMENT_SHADER,GL_HIGH_FLOAT,r,&p) -> true, r={127,127}, p=23
+//   MaybePrecision(GL_FRAGMENT_SHADER,GL_HIGH_INT,r,&p)   -> false (no INT data)
+//   GlVersion(true)                            -> "WebGL 2.0 (OpenGL ES 3.0 Chromium)"
+//   ExtensionAllowed("EXT_float_blend", false) -> true
+//   ExtensionAllowed("EXT_disjoint_timer_query_webgl2", false) -> false (webgl2-only)
+//   ExtensionAllowed("EXT_disjoint_timer_query_webgl2", true)  -> true
+// When the profile is inactive OR renderer/os matches no row:
+//   Active()==false, every Maybe*/Precision()==false (out untouched),
+//   Unmasked*/GlVersion/GlslVersion == empty String,
+//   ExtensionAllowed(...)==true  (never hides a real extension).
+// ---------------------------------------------------------------------------
+
+namespace blink {
+namespace webgl_persona {
+
+namespace {
+
+using data::PersonaEntry;
+
+// ASCII lowercase for a single char (locale-independent).
+char AsciiLower(char c) {
+  return (c >= 'A' && c <= 'Z') ? static_cast<char>(c - 'A' + 'a') : c;
+}
+
+// ASCII case-insensitive equality between a std::string and a C string.
+bool AsciiEqualIgnoreCase(const std::string& a, const char* b) {
+  std::size_t i = 0;
+  for (; i < a.size(); ++i) {
+    if (b[i] == '\0')
+      return false;
+    if (AsciiLower(a[i]) != AsciiLower(b[i]))
+      return false;
+  }
+  return b[i] == '\0';
+}
+
+// ASCII case-insensitive 'haystack contains needle'. Empty needle -> true.
+bool AsciiContainsIgnoreCase(const std::string& haystack, const char* needle) {
+  const std::size_t nlen = std::char_traits<char>::length(needle);
+  if (nlen == 0)
+    return true;
+  if (haystack.size() < nlen)
+    return false;
+  const std::size_t last = haystack.size() - nlen;
+  for (std::size_t start = 0; start <= last; ++start) {
+    std::size_t j = 0;
+    for (; j < nlen; ++j) {
+      if (AsciiLower(haystack[start + j]) != AsciiLower(needle[j]))
+        break;
+    }
+    if (j == nlen)
+      return true;
+  }
+  return false;
+}
+
+// Find the persona row matching the active descriptor, or nullptr.
+const PersonaEntry* ComputeMatch() {
+  fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (!profile.active())
+    return nullptr;
+  const fingerprint::Descriptor& d = profile.descriptor();
+  for (std::size_t i = 0; i < data::kPersonaTableCount; ++i) {
+    const PersonaEntry& e = data::kPersonaTable[i];
+    if (AsciiEqualIgnoreCase(d.os, e.os) &&
+        AsciiContainsIgnoreCase(d.gpu.renderer, e.renderer_substring)) {
+      return &e;
+    }
+  }
+  return nullptr;
+}
+
+// Profile is an immutable process singleton, so the match never changes; cache
+// it behind a thread-safe function-local static.
+const PersonaEntry* MatchedEntry() {
+  static const PersonaEntry* const entry = ComputeMatch();
+  return entry;
+}
+
+}  // namespace
+
+bool Active() {
+  return MatchedEntry() != nullptr;
+}
+
+bool MaybeInt(GLenum pname, GLint* out) {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e || !out)
+    return false;
+  for (std::size_t i = 0; i < e->int_caps_count; ++i) {
+    if (e->int_caps[i].pname == pname) {
+      *out = static_cast<GLint>(e->int_caps[i].value);
+      return true;
+    }
+  }
+  return false;
+}
+
+bool MaybeInt64(GLenum pname, GLint64* out) {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e || !out)
+    return false;
+  for (std::size_t i = 0; i < e->int64_caps_count; ++i) {
+    if (e->int64_caps[i].pname == pname) {
+      *out = static_cast<GLint64>(e->int64_caps[i].value);
+      return true;
+    }
+  }
+  return false;
+}
+
+bool MaybeFloat(GLenum pname, GLfloat* out) {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e || !out)
+    return false;
+  for (std::size_t i = 0; i < e->float_caps_count; ++i) {
+    if (e->float_caps[i].pname == pname) {
+      *out = static_cast<GLfloat>(e->float_caps[i].value);
+      return true;
+    }
+  }
+  return false;
+}
+
+bool MaybeFloatArray2(GLenum pname, GLfloat out[2]) {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e || !out)
+    return false;
+  for (std::size_t i = 0; i < e->float_arr2_caps_count; ++i) {
+    if (e->float_arr2_caps[i].pname == pname) {
+      out[0] = static_cast<GLfloat>(e->float_arr2_caps[i].v0);
+      out[1] = static_cast<GLfloat>(e->float_arr2_caps[i].v1);
+      return true;
+    }
+  }
+  return false;
+}
+
+bool MaybeIntArray2(GLenum pname, GLint out[2]) {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e || !out)
+    return false;
+  for (std::size_t i = 0; i < e->int_arr2_caps_count; ++i) {
+    if (e->int_arr2_caps[i].pname == pname) {
+      out[0] = static_cast<GLint>(e->int_arr2_caps[i].v0);
+      out[1] = static_cast<GLint>(e->int_arr2_caps[i].v1);
+      return true;
+    }
+  }
+  return false;
+}
+
+bool MaybePrecision(GLenum shader_type,
+                    GLenum precision_type,
+                    GLint range_out[2],
+                    GLint* precision_out) {
+  (void)shader_type;  // Persona value is stage-invariant on real desktop GPUs.
+  const PersonaEntry* e = MatchedEntry();
+  if (!e || !e->has_float_precision || !range_out || !precision_out)
+    return false;
+  // Only FLOAT precision formats are captured in the dataset.
+  if (precision_type != GL_LOW_FLOAT && precision_type != GL_MEDIUM_FLOAT &&
+      precision_type != GL_HIGH_FLOAT) {
+    return false;
+  }
+  range_out[0] = static_cast<GLint>(e->float_precision[0]);
+  range_out[1] = static_cast<GLint>(e->float_precision[1]);
+  *precision_out = static_cast<GLint>(e->float_precision[2]);
+  return true;
+}
+
+String UnmaskedVendor() {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e)
+    return String();
+  return String::FromUtf8(fingerprint::Profile::Get().descriptor().gpu.vendor);
+}
+
+String UnmaskedRenderer() {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e)
+    return String();
+  return String::FromUtf8(
+      fingerprint::Profile::Get().descriptor().gpu.renderer);
+}
+
+String GlVersion(bool webgl2) {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e)
+    return String();
+  return String::FromUtf8(webgl2 ? e->gl_version_webgl2
+                                      : e->gl_version_webgl1);
+}
+
+String GlslVersion(bool webgl2) {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e)
+    return String();
+  return String::FromUtf8(webgl2 ? e->glsl_version_webgl2
+                                      : e->glsl_version_webgl1);
+}
+
+bool ExtensionAllowed(const String& name, bool webgl2) {
+  const PersonaEntry* e = MatchedEntry();
+  if (!e)
+    return true;  // Inactive/unmatched: never hide a real extension.
+  const char* const* list = webgl2 ? e->extensions2 : e->extensions1;
+  const std::size_t count = webgl2 ? e->extensions2_count : e->extensions1_count;
+  const std::string needle = name.Utf8();
+  for (std::size_t i = 0; i < count; ++i) {
+    if (AsciiEqualIgnoreCase(needle, list[i]))
+      return true;
+  }
+  return false;
+}
+
+}  // namespace webgl_persona
+}  // namespace blink
diff --git a/third_party/blink/renderer/modules/webgl/webgl_persona_params.h b/third_party/blink/renderer/modules/webgl/webgl_persona_params.h
new file mode 100644
index 0000000000000..6d60afa6cd90b
--- /dev/null
+++ b/third_party/blink/renderer/modules/webgl/webgl_persona_params.h
@@ -0,0 +1,84 @@
+// Copyright 2026 The Raven Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license.
+//
+// webgl_persona::* — the single WebGL-side reader of the persona GPU profile.
+//
+// Raven spoofs a *consistent* GPU identity: fingerprint::Profile carries the
+// descriptor's gpu.{vendor,renderer}; this module maps that renderer to one row
+// of the generated persona param table (webgl_persona_params_data.h) and serves
+// the matching WebGL/WebGL2 getParameter caps, getShaderPrecisionFormat values,
+// VERSION / SHADING_LANGUAGE_VERSION strings, and the extension allow-list.
+//
+// FAIL-SAFE CONTRACT: when the profile is inactive, or the active descriptor's
+// renderer/os does not match any table row, every Maybe*/Precision accessor
+// returns false and every string accessor returns an empty String, so the WebGL
+// code path falls back to the real host values (stock behavior). ExtensionAllowed
+// returns true when inactive/unmatched so no real extension is ever hidden.
+//
+// A row matches iff descriptor.os equals the row's os (ASCII case-insensitive)
+// AND descriptor.gpu.renderer contains the row's renderer_substring (ASCII
+// case-insensitive 'contains'). The match is computed once (Profile is an
+// immutable process singleton) and cached.
+
+#ifndef THIRD_PARTY_BLINK_RENDERER_MODULES_WEBGL_WEBGL_PERSONA_PARAMS_H_
+#define THIRD_PARTY_BLINK_RENDERER_MODULES_WEBGL_WEBGL_PERSONA_PARAMS_H_
+
+#include "third_party/blink/renderer/platform/wtf/text/wtf_string.h"
+#include "third_party/khronos/GLES2/gl2.h"  // GLenum, GLint, GLint64, GLfloat
+
+namespace blink {
+namespace webgl_persona {
+
+// True iff Profile::Get().active() AND the descriptor's renderer+os matched a
+// persona table row. All other accessors key off this same condition.
+bool Active();
+
+// Integer getParameter caps (MAX_TEXTURE_SIZE, MAX_SAMPLES, ...). Writes *out
+// and returns true on a hit; returns false (leaving *out untouched) when
+// inactive/unmatched or pname is not a spoofed cap.
+bool MaybeInt(GLenum pname, GLint* out);
+
+// WebGL2 64-bit caps (MAX_ELEMENT_INDEX, MAX_UNIFORM_BLOCK_SIZE, ...).
+bool MaybeInt64(GLenum pname, GLint64* out);
+
+// Float caps (MAX_TEXTURE_LOD_BIAS).
+bool MaybeFloat(GLenum pname, GLfloat* out);
+
+// Float pair caps (ALIASED_LINE_WIDTH_RANGE, ALIASED_POINT_SIZE_RANGE).
+bool MaybeFloatArray2(GLenum pname, GLfloat out[2]);
+
+// Int pair caps (MAX_VIEWPORT_DIMS).
+bool MaybeIntArray2(GLenum pname, GLint out[2]);
+
+// getShaderPrecisionFormat: for FLOAT precision types (LOW/MEDIUM/HIGH_FLOAT)
+// writes range_out[0..1] and *precision_out and returns true. Returns false for
+// INT precision types (not captured in the dataset) and when inactive/unmatched.
+// shader_type is accepted for signature parity; the persona value is identical
+// for the vertex and fragment stages, as observed on real desktop GPUs.
+bool MaybePrecision(GLenum shader_type,
+                    GLenum precision_type,
+                    GLint range_out[2],
+                    GLint* precision_out);
+
+// UNMASKED_VENDOR_WEBGL: descriptor.gpu.vendor when active, else empty String.
+String UnmaskedVendor();
+
+// UNMASKED_RENDERER_WEBGL: descriptor.gpu.renderer when active, else empty.
+String UnmaskedRenderer();
+
+// VERSION: full "WebGL 1.0 (...)" / "WebGL 2.0 (...)" when active, else empty.
+String GlVersion(bool webgl2);
+
+// SHADING_LANGUAGE_VERSION: "WebGL GLSL ES 1.0 (...)" / "...3.00 (...)" when
+// active, else empty.
+String GlslVersion(bool webgl2);
+
+// True if inactive/unmatched (allow real extension) OR `name` is present in the
+// active persona's WebGL1 (webgl2==false) / WebGL2 (webgl2==true) extension
+// list. ASCII case-insensitive. Used to gate getSupportedExtensions/getExtension.
+bool ExtensionAllowed(const String& name, bool webgl2);
+
+}  // namespace webgl_persona
+}  // namespace blink
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_MODULES_WEBGL_WEBGL_PERSONA_PARAMS_H_
