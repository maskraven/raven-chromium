+// Returns true iff the currently loaded (potentially externally-swapped)
+// libffmpeg.so provides an H.264 decoder. When built without FFmpeg,
+// proprietary-codec support is provided by platform decoders, so the historical
+// behavior (unconditional support) is preserved.
+bool IsExternalH264DecoderAvailable() {
+#if BUILDFLAG(ENABLE_FFMPEG)
+  static const bool kAvailable =
+      avcodec_find_decoder(AV_CODEC_ID_H264) != nullptr;
+  return kAvailable;
+#else
+  return true;
+#endif  // BUILDFLAG(ENABLE_FFMPEG)
+}
+
+// Returns true iff the currently loaded libffmpeg.so provides an AAC decoder.
+// See IsExternalH264DecoderAvailable() for the non-FFmpeg rationale.
+bool IsExternalAacDecoderAvailable() {
+#if BUILDFLAG(ENABLE_FFMPEG)
+  static const bool kAvailable =
+      avcodec_find_decoder(AV_CODEC_ID_AAC) != nullptr;
+  return kAvailable;
+#else
+  return true;
+#endif  // BUILDFLAG(ENABLE_FFMPEG)
+}
