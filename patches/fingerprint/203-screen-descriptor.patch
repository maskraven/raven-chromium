 int Screen::height() const {
+  // Raven descriptor (Plan 03): screen.height co-varies with the persona; read
+  // verbatim from the process-global fingerprint::Profile. Precedence:
+  // default < descriptor (the --fingerprint-screen-* switches are unwired).
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active() && profile.descriptor().screen.h > 0) {
+    return profile.descriptor().screen.h;
+  }
+
   if (!DomWindow())
     return 0;
   return GetRect(/*available=*/false).height();
 }
 
