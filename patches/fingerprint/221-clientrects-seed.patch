+  if (fingerprint::Profile::Get().active()) {
+    // Re-key client-rects jitter to the descriptor seed (design §1). Two draws
+    // from the canvas surface stream give statistically independent x/y noise
+    // factors, each mapped into ±0.001px. Named locals: C++ arg-eval order is
