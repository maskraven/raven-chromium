+    // unit in [0,1) -> signed factor in [-1,1) * 0.001px.
+    noise_factor_x_ = (unit_x * 2.0 - 1.0) * 0.001;
+    noise_factor_y_ = (unit_y * 2.0 - 1.0) * 0.001;
