 bool DOMPluginArray::IsPdfViewerAvailable() {
+  // Raven descriptor (Plan 03): the internal PDF viewer is Chrome's fixed,
+  // spec'd plugin set and is enabled on every v1 (desktop) persona. This method
+  // is the single source feeding BOTH navigator.plugins (the hard-coded list
+  // above) AND navigator.pdfViewerEnabled, so reporting it unconditionally when
+  // a profile is active keeps the pair stable + coherent across hosts,
+  // independent of the host's registered PluginData. No exotic plugins are
+  // fabricated — only Chrome's standard PDF viewer set is exposed.
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active()) {
+    return true;
+  }
+
   auto* data = GetPluginData();
   if (!data)
     return false;
