+// Raven: append one canned voice to |voice_list| as a GC-managed
+// SpeechSynthesisVoice. voiceURI mirrors the name (as real engines do for these
+// voices). All arguments are ASCII literals, so String's Latin-1 const char*
+// constructor is exact.
+void AppendPersonaVoice(HeapVector<Member<SpeechSynthesisVoice>>& voice_list,
+                        const char* name,
+                        const char* lang,
+                        bool is_local_service,
+                        bool is_default) {
+  auto voice = mojom::blink::SpeechSynthesisVoice::New();
+  voice->voice_uri = String(name);
+  voice->name = String(name);
+  voice->lang = String(lang);
+  voice->is_local_service = is_local_service;
+  voice->is_default = is_default;
+  voice_list.push_back(
+      MakeGarbageCollected<SpeechSynthesisVoice>(std::move(voice)));
+}
+
+// Builds a deterministic, OS-appropriate TTS voice list for the active persona.
+// Exactly one entry is default=true. Real Chrome exposes voices on every desktop
+// OS, so an empty list (the host's neutral state) is itself a tell; this canned
+// list restores coherence without leaking the host's real inventory. Data
+// mirrors the stock voices shipped by each platform plus Google's network voices
+// (present on every OS, localService=false). The list is kept small and stable.
+void BuildPersonaVoiceList(HeapVector<Member<SpeechSynthesisVoice>>& voice_list,
+                           const std::string& os) {
+  const bool has_local_default = (os == "windows" || os == "macos");
+
+  // OS-native local voices first (localService=true).
+  if (os == "windows") {
+    AppendPersonaVoice(voice_list, "Microsoft David - English (United States)",
+                       "en-US", /*is_local_service=*/true, /*is_default=*/true);
+    AppendPersonaVoice(voice_list, "Microsoft Zira - English (United States)",
+                       "en-US", /*is_local_service=*/true,
+                       /*is_default=*/false);
+    AppendPersonaVoice(voice_list, "Microsoft Mark - English (United States)",
+                       "en-US", /*is_local_service=*/true,
+                       /*is_default=*/false);
+  } else if (os == "macos") {
+    AppendPersonaVoice(voice_list, "Samantha", "en-US",
+                       /*is_local_service=*/true, /*is_default=*/true);
+    AppendPersonaVoice(voice_list, "Alex", "en-US", /*is_local_service=*/true,
+                       /*is_default=*/false);
+    AppendPersonaVoice(voice_list, "Daniel", "en-GB", /*is_local_service=*/true,
+                       /*is_default=*/false);
+    AppendPersonaVoice(voice_list, "Karen", "en-AU", /*is_local_service=*/true,
+                       /*is_default=*/false);
+  }
+  // else: linux (and any unknown os) exposes no local voices.
+
+  // Google network voices, present on every OS (localService=false). When no
+  // local default was set (linux/unknown), the first Google voice is default so
+  // that exactly one voice remains the default.
+  AppendPersonaVoice(voice_list, "Google US English", "en-US",
+                     /*is_local_service=*/false,
+                     /*is_default=*/!has_local_default);
+  AppendPersonaVoice(voice_list, "Google UK English Female", "en-GB",
+                     /*is_local_service=*/false, /*is_default=*/false);
+  AppendPersonaVoice(voice_list, "Google UK English Male", "en-GB",
+                     /*is_local_service=*/false, /*is_default=*/false);
+  AppendPersonaVoice(voice_list, "Google Deutsch", "de-DE",
+                     /*is_local_service=*/false, /*is_default=*/false);
+}
