 const HeapVector<Member<SpeechSynthesisVoice>>& SpeechSynthesis::getVoices() {
+  // Raven descriptor (Plan 03): the installed TTS voice list is strongly
+  // OS-derived and one of the highest-entropy fingerprint vectors on the
+  // platform. Rather than leak the host's real voices, expose a DETERMINISTIC,
+  // OS-appropriate canned list keyed on descriptor().os. Real Chrome shows
+  // voices on every desktop OS, so an empty list would itself be a coherence
+  // tell. The list is built once and cached in voice_list_ (stable across
+  // observations); the host's real voices arriving via OnSetVoiceList are
+  // ignored while active, so this reference stays canned and valid.
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active()) {
+    if (voice_list_.empty())
+      BuildPersonaVoiceList(voice_list_, profile.descriptor().os);
+    return voice_list_;
+  }
