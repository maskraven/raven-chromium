 const String& GPUAdapterInfo::vendor() const {
+  // Raven descriptor (Plan 03): report the persona's GPU vendor verbatim so the
+  // WebGPU adapter co-varies with WebGL UNMASKED_VENDOR (patch 011). The stored
+  // spoof outlives the call (function-local NoDestructor) so the getter can keep
+  // returning a reference; the process-global descriptor is immutable.
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active() && !profile.descriptor().gpu.vendor.empty()) {
+    static const base::NoDestructor<String> spoofed(
+        String::FromUtf8(profile.descriptor().gpu.vendor));
+    return *spoofed;
+  }
   return vendor_;
 }
 
 const String& GPUAdapterInfo::architecture() const {
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active() && !profile.descriptor().gpu.architecture.empty()) {
+    static const base::NoDestructor<String> spoofed(
+        String::FromUtf8(profile.descriptor().gpu.architecture));
+    return *spoofed;
+  }
   return architecture_;
 }
 
 const String& GPUAdapterInfo::device() const {
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active() && !profile.descriptor().gpu.device.empty()) {
+    static const base::NoDestructor<String> spoofed(
+        String::FromUtf8(profile.descriptor().gpu.device));
+    return *spoofed;
+  }
   return device_;
 }
 
 const String& GPUAdapterInfo::description() const {
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active()) {
+    const fingerprint::Descriptor::Gpu& gpu = profile.descriptor().gpu;
+    if (!gpu.vendor.empty() || !gpu.device.empty()) {
+      static const base::NoDestructor<String> spoofed(
+          String::FromUtf8(BuildGpuDescription(gpu)));
+      return *spoofed;
+    }
+  }
   return description_;
 }
 
