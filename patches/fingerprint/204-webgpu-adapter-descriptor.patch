+// Human-readable adapter description built from the persona's GPU identity,
+// mirroring how a real driver composes "<vendor> <device>". Kept coherent with
+// the WebGL UNMASKED strings (patch 011) since both read descriptor.gpu — the
+// single GPU source.
+std::string BuildGpuDescription(const fingerprint::Descriptor::Gpu& gpu) {
+  std::string description = gpu.vendor;
+  if (!gpu.device.empty()) {
+    if (!description.empty()) {
+      description += " ";
+    }
+    description += gpu.device;
+  }
+  return description;
+}
