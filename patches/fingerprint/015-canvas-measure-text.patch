+          text_metrics->Shuffle(noise_x);
+        }
       }
-    } else if (canvas) {
-      text_metrics->Shuffle(canvas->GetDocument().GetNoiseFactorX());
+    } else if (canvas && text.length() > 0) {
+      text_metrics->Shuffle(noise_x);
     }
   }
   return text_metrics;
