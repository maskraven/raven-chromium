 const Vector<String>& NavigatorLanguage::languages() {
+  // Raven descriptor (Plan 03): navigator.languages co-varies with the persona.
+  // Read renderer-side from the process-global fingerprint::Profile (no browser
+  // file I/O). NOTE: the Accept-Language request header derives from browser-side
+  // RendererPreferences.accept_languages and is a documented v1 coherence gap
+  // (a browser-startup descriptor parse is future work).
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active() && !profile.descriptor().languages.empty()) {
+    languages_.clear();
+    for (const std::string& lang : profile.descriptor().languages) {
+      languages_.push_back(String::FromUtf8(lang));
+    }
+    languages_dirty_ = false;
+    return languages_;
+  }
   EnsureUpdatedLanguage();
   return languages_;
 }
