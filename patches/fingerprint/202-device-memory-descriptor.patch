+#include "third_party/blink/renderer/platform/fingerprint/profile.h"
 
 namespace blink {
 
+namespace {
+
+// navigator.deviceMemory is spec-bucketed to {0.25,0.5,1,2,4,8}. Clamp the
+// descriptor value DOWN to the nearest allowed bucket so the exposed value is
+// always a legal member of the set (a value >8 is a tell — round down to 8).
+float ClampDeviceMemoryToBucket(double memory) {
+  constexpr float kBuckets[] = {0.25f, 0.5f, 1.0f, 2.0f, 4.0f, 8.0f};
+  float result = kBuckets[0];
+  for (float bucket : kBuckets) {
+    if (memory >= bucket) {
+      result = bucket;
+    }
+  }
+  return result;
+}
+
+}  // namespace
+
 float NavigatorDeviceMemory::deviceMemory() const {
+  // Raven descriptor (Plan 03): navigator.deviceMemory co-varies with the
+  // persona; read from the process-global fingerprint::Profile and spec-bucket
+  // it. Highest precedence sits above the baseline's fixed fallback below.
+  const fingerprint::Profile& profile = fingerprint::Profile::Get();
+  if (profile.active() && profile.descriptor().device_memory > 0) {
+    return ClampDeviceMemoryToBucket(profile.descriptor().device_memory);
+  }
+
   return 8;
   // return ApproximatedDeviceMemory::GetApproximatedDeviceMemory();
 }
